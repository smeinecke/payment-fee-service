.PHONY: test analyse mess format-check format audit install

COMPOSER_BIN ?= composer

install:
	$(COMPOSER_BIN) install

test:
	$(COMPOSER_BIN) test

analyse:
	$(COMPOSER_BIN) analyse

mess:
	$(COMPOSER_BIN) mess

format-check:
	$(COMPOSER_BIN) format-check

format:
	$(COMPOSER_BIN) format

audit:
	$(COMPOSER_BIN) audit
