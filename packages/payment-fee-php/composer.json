{
  "name": "smeinecke/payment-fee",
  "description": "Native PHP payment-provider fee calculation library.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "smeinecke"
    }
  ],
  "require": {
    "php": ">=8.2",
    "brick/math": "^0.12"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "autoload": {
    "psr-4": {
      "Smeinecke\\PaymentFee\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Smeinecke\\PaymentFee\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "format-check": "php-cs-fixer fix --dry-run --diff",
    "format": "php-cs-fixer fix",
    "audit": "composer audit"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": false
    }
  }
}
