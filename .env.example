PAYMENT_FEE_ENVIRONMENT=development
PAYMENT_FEE_LOG_LEVEL=INFO
PAYMENT_FEE_REFRESH_INTERVAL_SECONDS=86400
PAYMENT_FEE_ADMIN_TOKEN=
PAYMENT_FEE_HTTP_TIMEOUT_SECONDS=30
PAYMENT_FEE_FAIL_STARTUP_ON_DATA_ERROR=false
PAYMENT_FEE_VALIDATE_JSON_SCHEMA=true

# Configure providers via a JSON file or a JSON string in PAYMENT_FEE_PROVIDERS.
# PAYMENT_FEE_CONFIG_FILE=/etc/payment-fee-service/config.json
# PAYMENT_FEE_PROVIDERS={"paypal": {"data_url": "https://raw.githubusercontent.com/smeinecke/paypal-fee-data/main", "data_ref": "main"}, "stripe": {"data_url": "https://raw.githubusercontent.com/smeinecke/stripe-fee-data/main", "data_ref": "main"}}
