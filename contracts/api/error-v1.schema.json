{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smeinecke.github.io/payment-fee-service/schemas/error-v1.schema.json",
  "title": "Structured Error v1",
  "description": "Canonical structured error envelope returned by the /v1 API and thrown by libraries.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "UNKNOWN_PROVIDER",
            "UNKNOWN_MARKET",
            "PROVIDER_DATA_UNAVAILABLE",
            "QUOTE_NOT_AVAILABLE",
            "INSUFFICIENT_TRANSACTION_CONTEXT",
            "AMBIGUOUS_FEE_RULES",
            "UNSUPPORTED_FEE_SHAPE",
            "CURRENCY_MISMATCH",
            "DATASET_VALIDATION_ERROR"
          ]
        },
        "message": { "type": "string" },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["code", "message"]
    }
  },
  "required": ["error"]
}
